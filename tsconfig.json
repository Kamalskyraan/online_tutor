{
  "compilerOptions": {
    /* Output */
    "outDir": "./dist",
    "rootDir": "./src",

    /* Environment */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    /* Type Safety */
    "strict": true,

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Source maps */
    "sourceMap": true,

    /* Performance */
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/service/sms.service.ts"],
  "exclude": ["node_modules", "dist"]
}
